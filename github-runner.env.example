# Copy to github-runner.env beside docker-compose.github-runner.yml, then:
#   chmod 600 github-runner.env
# Do not commit github-runner.env.
#
# docker compose -f docker-compose.github-runner.yml --env-file github-runner.env up -d
#
# REPO_URL — Repo that will own this runner (HTTPS).
# ACCESS_TOKEN — PAT with permission to register repo runners (see myoung34 wiki).

REPO_URL=https://github.com/YOUR_ORG/YOUR_MOODLE_REPO
ACCESS_TOKEN=

# Optional
# RUNNER_NAME=ec2-harbor-runner
# LABELS=harbor,self-hosted,linux
# TRAEFIK_NETWORK_NAME=traefik_traefik

# After jobs work, set in compose: UNSET_CONFIG_VARS: "true" so ACCESS_TOKEN is not in job env.

# Harbor robot account for workflows (GitHub repo → Secrets and variables → Actions):
#   HARBOR_REGISTRY  docker.ec2-3-137-190-96.us-east-2.compute.amazonaws.com
#   HARBOR_USERNAME  robot$project+ci
#   HARBOR_PASSWORD  <secret>
