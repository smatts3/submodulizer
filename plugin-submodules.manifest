# --- Monorepos: one clone contains multiple plugin roots; scripts cannot map 1:1 ---
# https://github.com/kaltura/moodle_plugin.git
#   filter/kaltura
#   lib/editor/atto/plugins/kalturamedia
#   mod/kalvidassign
#   mod/kalvidres

